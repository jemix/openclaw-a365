{
  "name": "@jemix/openclaw-a365",
  "version": "1.3.1",
  "description": "OpenClaw A365 (Microsoft 365 Agents) channel plugin with Graph API tools",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json || true",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "config",
    "docs"
  ],
  "devDependencies": {
    "@types/node": "^25.0.0",
    "openclaw": "^2026.3.22",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@mariozechner/pi-agent-core": "0.52.9",
    "@microsoft/agents-activity": "^1.1.0",
    "@microsoft/agents-hosting": "^1.1.0",
    "@microsoft/agents-hosting-express": "^1.1.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@sinclair/typebox": "0.34.48",
    "express": "^4.21.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
